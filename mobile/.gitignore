# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.
android/
ios/
.expo/
# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build
/dist

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
# NOTE: .env holds PRODUCTION defaults and is what OTA bundles bake in
# (eas update -> expo export loads it). Local dev overrides belong in
# .env.development.local — loaded ONLY when NODE_ENV=development, so they can
# never leak into an OTA. Never put the API URL in .env.local (Expo loads that
# in every environment, incl. production exports).
.env*
.env
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts