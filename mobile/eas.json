{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://maxapp-api.onrender.com/api/"
      },
      "ios": {
        "simulator": false
      }
    },
    "preview": {
      "channel": "preview",
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "channel": "production",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://maxapp-api.onrender.com/api/",
        "RCT_NEW_ARCH_ENABLED": "1"
      },
      "autoIncrement": true,
      "ios": {
        "autoIncrement": false
      },
      "android": {
        "buildType": "app-bundle"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6761345332",
        "appleTeamId": "3TJ8RC3JCX",
        "bundleIdentifier": "com.cannon.mobile"
      }
    }
  }
}
