# Production defaults — these ship in OTA bundles (eas update runs expo export,
# which loads .env in production mode). Keep real prod values here.
EXPO_PUBLIC_API_BASE_URL=https://maxapp-api.onrender.com/api/
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_disabled
EXPO_PUBLIC_SUPPORT_EMAIL=support@local.test
EXPO_PUBLIC_PRIVACY_POLICY_URL=https://maxmaxmax.today/legal/privacy
EXPO_PUBLIC_TERMS_URL=https://maxmaxmax.today/legal/terms

# LOCAL DEV OVERRIDES: put them in .env.development.local (gitignored).
# It is loaded ONLY when NODE_ENV=development (expo start), so it can never
# leak into an OTA bundle. Example:
#   EXPO_PUBLIC_API_BASE_URL=http://localhost:8002/api/
# NEVER use .env.local for this — Expo loads it in EVERY environment,
# including production exports, which ships localhost to every phone.
