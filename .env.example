# =============================================================================
# Max App -- environment template. Copy to `.env` and fill in real values.
# =============================================================================

# --- LLM / chat completions --------------------------------------------------
# Chat goes through a Hugging Face Dedicated Inference Endpoint via the OpenAI
# SDK compatibility layer. Set HF_TOKEN to your HF API token.
LLM_PROVIDER=huggingface
HF_TOKEN=
HF_ENDPOINT_URL=https://pr83qgnhfqomb51f.us-east-1.aws.endpoints.huggingface.cloud/v1
HF_MODEL=tgi

# --- Vision / face scans (still required) ------------------------------------
# The HF TGI text endpoint cannot accept image input, so face-scan analysis
# (UMax + full triple scans) still goes through OpenAI or Gemini. Keep at
# least one of these set; otherwise scan endpoints will return error stubs.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- App ---------------------------------------------------------------------
APP_NAME=Max
APP_ENV=development
DEBUG=true
API_VERSION=v1
CORS_ORIGINS=http://localhost:3000,http://localhost:8081,http://127.0.0.1:8081

# --- JWT ---------------------------------------------------------------------
JWT_SECRET_KEY=change-this-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_REFRESH_TOKEN_EXPIRE_DAYS=300

# --- Supabase (user-specific data) -------------------------------------------
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_HOST=
SUPABASE_DB_PORT=6543
SUPABASE_DB_USER=
SUPABASE_DB_PASSWORD=
SUPABASE_DB_NAME=postgres

# --- AWS RDS (shared data) ---------------------------------------------------
AWS_RDS_HOST=
AWS_RDS_PORT=5432
AWS_RDS_USER=
AWS_RDS_PASSWORD=
AWS_RDS_DATABASE=cannon_shared

# --- AWS S3 ------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=cannon-app-uploads
AWS_S3_REGION=us-west-1

# --- MongoDB -----------------------------------------------------------------
MONGODB_URI=
MONGODB_DATABASE=cannon_db

# --- Stripe ------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# --- Chat orchestration ------------------------------------------------------
CHAT_USE_LANGGRAPH=true
CHAT_MAX_CONTEXT_TOKENS=8000
# LLM-driven per-max onboarding (reads known user facts, skips repeats).
DYNAMIC_ONBOARDING_ENABLED=true

# --- Rate limiting -----------------------------------------------------------
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD_SECONDS=60
